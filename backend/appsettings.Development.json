{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=ramensite.db"
  },
  "Jwt": {
    "Key": "dev-only-signing-key-change-me-in-production-please-32chars+",
    "Issuer": "RamenSite",
    "Audience": "RamenSiteClient",
    "ExpiryMinutes": 15,
    "RefreshTokenDays": 7,
    "RefreshTokenAbsoluteDays": 30
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173", "http://localhost:5174"]
  },
  "RateLimiting": {
    "GlobalPermitLimit": 200,
    "AuthPermitLimit": 30,
    "WindowSeconds": 60
  }
}
