@RamenSite.Api_HostAddress = http://localhost:5105
@token = PASTE_JWT_HERE

### 店舗一覧（検索・絞り込み）
GET {{RamenSite.Api_HostAddress}}/api/shops?genre=味噌
Accept: application/json

### 店舗詳細
GET {{RamenSite.Api_HostAddress}}/api/shops/1
Accept: application/json

### ログイン（シード済み管理者）
POST {{RamenSite.Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@ramen.test",
  "password": "adminpass123"
}

### 店舗のレビュー一覧（公開）
GET {{RamenSite.Api_HostAddress}}/api/shops/1/reviews
Accept: application/json

### レビュー投稿/更新（要認証）
POST {{RamenSite.Api_HostAddress}}/api/shops/1/reviews
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "rating": 5,
  "comment": "最高の一杯でした。"
}

### お気に入り追加（要認証）
PUT {{RamenSite.Api_HostAddress}}/api/favorites/1
Authorization: Bearer {{token}}

### お気に入り一覧（要認証）
GET {{RamenSite.Api_HostAddress}}/api/favorites
Authorization: Bearer {{token}}

### 店舗の新規追加（管理者のみ）
POST {{RamenSite.Api_HostAddress}}/api/shops
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "新店 テスト",
  "description": "新しく追加した店舗。",
  "address": "東京都新宿区1-1-1",
  "area": "東京",
  "genre": "醤油",
  "openingHours": "11:00〜22:00",
  "priceRange": "〜1000円",
  "imageUrl": "https://images.unsplash.com/photo-1591814468924-caf88d1232e1?w=800"
}

###
